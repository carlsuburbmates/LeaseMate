# ==============================================================================
# LEASEMATE LOCAL DEVELOPMENT ENVIRONMENT
# Copy this file to .env and fill in the values before running `pnpm run dev`.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APP SETTINGS
# ------------------------------------------------------------------------------
# The public base URL of your local server.
APP_URL=http://localhost:3000

# The database connection string. You must run a local MySQL/MariaDB instance
# or use a cloud database (like TiDB or PlanetScale) for local development.
# Example format: mysql://user:password@localhost:3306/leasemate
DATABASE_URL=mysql://root:@127.0.0.1:3306/leasemate

# A random secret used to sign session cookies. Generate one with `openssl rand -hex 32`.
JWT_SECRET=super_secret_local_dev_key_change_me

# The ID of the app (used by the auth system). You can use a dummy value locally.
VITE_APP_ID=local_leasemate_app

# The OpenID of the admin user. When you log in, check the database `users` table
# for your `openId` and paste it here to grant yourself admin privileges.
OWNER_OPEN_ID=your_admin_open_id_here

# ------------------------------------------------------------------------------
# 2. AUTHENTICATION (OAUTH)
# ------------------------------------------------------------------------------
# In Manus, this points to the platform OAuth server.
# For local development, you need a mock OAuth server or a compatible provider.
# If you don't have one, you will need to manually insert a user into the DB
# and manually set a signed JWT cookie to bypass the login flow.
OAUTH_SERVER_URL=https://mock-oauth-server.local

# ------------------------------------------------------------------------------
# 3. STRIPE PAYMENTS (OPTIONAL)
# ------------------------------------------------------------------------------
# Get these from your Stripe Dashboard (Test Mode).
# If left blank, the app will still start, but payment routes will throw errors.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# 4. EXTERNAL SERVICES (OPTIONAL)
# ------------------------------------------------------------------------------
# Resend (Email delivery)
# If left blank, emails will silently fail without crashing the app.
RESEND_API_KEY=re_...

# Google Maps (Frontend)
# Required for address autocomplete and maps. Get from Google Cloud Console.
# If left blank, maps will fail to load with a console warning.
VITE_GOOGLE_MAPS_API_KEY=AIza...

# ------------------------------------------------------------------------------
# 5. MANUS PLATFORM SERVICES (LEAVE BLANK LOCALLY)
# ------------------------------------------------------------------------------
# These are injected automatically when running inside Manus.
# Leave them blank locally to enable the local-disk storage fallback.
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_OAUTH_PORTAL_URL=
