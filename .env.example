# ==============================================================================
# LEASEMATE LOCAL DEVELOPMENT ENVIRONMENT
# Copy this file to .env and fill in the values before running `pnpm run dev`.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APP SETTINGS
# ------------------------------------------------------------------------------
# The public base URL of your local server.
APP_URL=http://localhost:3000

# The database connection string. You must run a local MySQL/MariaDB instance
# or use a cloud database (like TiDB or PlanetScale) for local development.
# Example format: mysql://user:password@localhost:3306/leasemate
DATABASE_URL=mysql://root:@127.0.0.1:3306/leasemate

# A random secret used to sign session cookies. Generate one with `openssl rand -hex 32`.
JWT_SECRET=super_secret_local_dev_key_change_me

# The ID of the app (used by the auth system). You can use a dummy value locally.
VITE_APP_ID=local_leasemate_app

# Where owner/operator fallback alerts should be emailed when Forge is absent.
OWNER_EMAIL=owner@example.com

# Optional legacy owner OpenID override. Local auth can also create an `admin`
# or `operator` user directly from the `/login` screen.
OWNER_OPEN_ID=

# ------------------------------------------------------------------------------
# 2. AUTHENTICATION
# ------------------------------------------------------------------------------
# Default local-first mode. This enables `/login` and local DB-backed sessions.
AUTH_MODE=local
VITE_AUTH_MODE=local

# Manus-compatible OAuth is optional now. Leave these blank locally unless you
# explicitly want to test the old hosted auth flow.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# ------------------------------------------------------------------------------
# 3. STRIPE PAYMENTS (OPTIONAL)
# ------------------------------------------------------------------------------
# Get these from your Stripe Dashboard (Test Mode).
# If left blank, the app will still start, but payment routes will throw errors.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# 4. EXTERNAL SERVICES (OPTIONAL)
# ------------------------------------------------------------------------------
# Resend (Email delivery)
# If left blank, emails will silently fail without crashing the app.
RESEND_API_KEY=re_...

# Background jobs
# Local development uses an in-process scheduler by default. For durable
# delayed jobs in production, configure QStash plus signing keys.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Used by Vercel Cron for the daily stale-request cleanup endpoint.
CRON_SECRET=replace_with_a_long_random_secret

# Optional override for internal automation callbacks. Falls back to
# CRON_SECRET, then JWT_SECRET, if omitted.
INTERNAL_JOB_SECRET=

# ------------------------------------------------------------------------------
# 5. OBJECT STORAGE
# ------------------------------------------------------------------------------
# Recommended production path: S3-compatible object storage such as
# Cloudflare R2 or AWS S3. When these are configured, LeaseMate will use
# remote object storage instead of local ./uploads.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional public base URL if your bucket is public or behind a CDN.
# Example: https://pub-xxxxxxxx.r2.dev/uploads
S3_PUBLIC_BASE_URL=

# Set true for some S3-compatible providers that require path-style URLs.
S3_FORCE_PATH_STYLE=false

# ------------------------------------------------------------------------------
# 6. MANUS PLATFORM SERVICES (LEAVE BLANK LOCALLY)
# ------------------------------------------------------------------------------
# These are injected automatically when running inside Manus.
# Leave them blank locally unless you intentionally switch AUTH_MODE=manus.
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=
